# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Generated font data (rebuilt from @fontsource/* packages)
packages/fonts/src/generated/

# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test
coverage/
.debug/

# Producer regression test failures (generated debugging artifacts)
packages/producer/tests/*/failures/

# Rendered output (not test fixtures — those use git LFS)
output/
!packages/producer/tests/*/output/

# npm pack artifacts
*.tgz

# Logs
*.log
npm-debug.log*

# Temporary
tmp/
.tmp/
